{
  "manifest_version": 3,
  "name": "YouTube Dual Subtitles",
  "description": "Step 12: debounces rapid caption changes before translation.",
  "version": "0.12.0",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://translate.googleapis.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "YouTube Dual Subtitles"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.youtube.com/*",
        "https://m.youtube.com/*"
      ],
      "js": [
        "src/translationState.js",
        "src/overlayPosition.js",
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
