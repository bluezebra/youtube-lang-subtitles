{
  "manifest_version": 3,
  "name": "YouTube Dual Subtitles",
  "description": "Step 6: translates live Finnish YouTube captions in a borderless overlay that hides native captions.",
  "version": "0.6.0",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://translate.googleapis.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "YouTube Dual Subtitles"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.youtube.com/*",
        "https://m.youtube.com/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
